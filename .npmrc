# .npmrc (configuração recomendada para projeto Node/Angular/PrimeNG)

# Registro padrão
registry=https://registry.npmjs.org/

# Instalação e versionamento
save-exact=true
package-lock=true
engine-strict=true
legacy-peer-deps=false
strict-peer-deps=false

# Qualidade/segurança
audit=true
fund=false

# Performance/rede
prefer-offline=true
progress=false
fetch-retries=3
fetch-retry-factor=10
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
network-timeout=60000

# Logs
loglevel=warn

# Cache local do projeto
cache=.npm-cache

# Se usar registry privado, descomente e ajuste:
# @seu-scope:registry=https://npm.pkg.github.com/
# //npm.pkg.github.com/:_authToken=${NPM_TOKEN}
# always-auth=true